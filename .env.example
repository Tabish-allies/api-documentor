# =============================================================
# API Documentor - Environment Configuration
# =============================================================
# Copy this file to .env and update the values as needed.
# Default values work out of the box for local development.
# =============================================================

# Application
APP_NAME=api-documentor
SERVER_PORT=8080

# Database Configuration
# Default: H2 in-memory database (no setup required)
# For production, replace with your preferred database (PostgreSQL, MySQL, etc.)
DATASOURCE_URL=jdbc:h2:mem:apidocs
DATASOURCE_DRIVER=org.h2.Driver
DATASOURCE_USERNAME=sa
DATASOURCE_PASSWORD=
JPA_PLATFORM=org.hibernate.dialect.H2Dialect
JPA_DDL_AUTO=create-drop
H2_CONSOLE_ENABLED=true

# =============================================================
# Production Database Example (PostgreSQL)
# =============================================================
# DATASOURCE_URL=jdbc:postgresql://localhost:5432/apidocs
# DATASOURCE_DRIVER=org.postgresql.Driver
# DATASOURCE_USERNAME=your_db_username
# DATASOURCE_PASSWORD=your_db_password
# JPA_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
# JPA_DDL_AUTO=update
# H2_CONSOLE_ENABLED=false
